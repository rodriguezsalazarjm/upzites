# Copy this file to .env.local and fill in the value.
# In production (e.g. your host/Vercel), set the same variable in the project's
# Environment Variables.
#
# PageSpeed Insights API key for the free site-audit tool.
# It is used from the browser (client-side), so restrict it by HTTP referrer
# (e.g. https://www.upzites.com/*) in Google Cloud Console — NOT by IP or API
# only, since the request carries the site's referrer.
NEXT_PUBLIC_PAGESPEED_KEY=

# Meta Pixel ID. Override this in Vercel if the account changes.
NEXT_PUBLIC_META_PIXEL_ID=1009533758712390

# Optional comma-separated list for multiple pixels.
NEXT_PUBLIC_META_PIXEL_IDS=

# Set to true only when a marketing-cookie consent gate must block Meta tracking
# until the user accepts. Leaving this false keeps Meta's setup tool detection simple.
NEXT_PUBLIC_META_PIXEL_REQUIRE_CONSENT=false
